generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  walletAddress String?
  role          String?
  createdAt     DateTime @default(now())
}